nk>\r\n                            <span className=\"post-date\">August 8,2021</span>\r\n                          </div>\r\n                        </li>\r\n\r\n                        <li>\r\n                          <div className=\"thumb\">\r\n                            <Link to=\"/recdetails\">\r\n                              {\" \"}\r\n                              <img\r\n                                src={\"../img/vadapav.jpg\"}\r\n                                alt=\"thumbnail\"\r\n                              />{\" \"}\r\n                            </Link>\r\n                          </div>\r\n                          <div className=\"detail\">\r\n                            <Link to=\"/recdetails\">VADA PAV</Link>\r\n                            <span className=\"post-date\">October 12,2021</span>\r\n                          </div>\r\n                        </li>\r\n                      </ul>\r\n                    </div>\r\n\r\n                    <div className=\"widget widget-get-social\">\r\n                      <h2>get social</h2>\r\n                      <ul>\r\n                        <li className=\"facebook\">\r\n                          <Link to=\"/recdetails\">\r\n                            <i className=\"fa fa-facebook\"></i>\r\n                            <span className=\"count\">23.5K</span>\r\n                            <span className=\"count-type\">Likes</span>\r\n                          </Link>\r\n                        </li>\r\n                        <li className=\"twitter\">\r\n                          <Link to=\"/recdetails\">\r\n                            <i className=\"fa fa-twitter\"></i>\r\n                            <span className=\"count\">23.5K</span>\r\n                            <span className=\"count-type\">Likes</span>\r\n                          </Link>\r\n                        </li>\r\n                        <li className=\"google-plus\">\r\n                          <Link to=\"/recdetails\