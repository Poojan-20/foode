profile.country,\r\n      profile.phone\r\n    );\r\n    setProfile({\r\n      firstname: \"\",\r\n      lastname: \"\",\r\n      address: \"\",\r\n      city: \"\",\r\n      state: \"\",\r\n      pincode: \"\",\r\n      country: \"\",\r\n      phone: \"\",\r\n    });\r\n    history.push(\"/profilelanding\");\r\n    Address();\r\n  };\r\n  \r\n  const onChange = (e) => {\r\n    setProfile({ ...profile, [e.target.name]: e.target.value });\r\n  };\r\n  return (\r\n    <>\r\n    {loading && <Spinner/>}\r\n      <Navbar />\r\n      <form className=\"ftco-section\" onSubmit={onSubmit}>\r\n        <div className=\"containerr\">\r\n          <section id=\"main\">\r\n            <header class=\"page-header mb-30\">\r\n              <h1> New address</h1>\r\n            </header>\r\n          </section>\r\n          <div className=\"row justify-content-center\">\r\n            <div className=\"col-md-12 col-lg-10\">\r\n              <div className=\"wrap \">\r\n                <div className=\"p-4 p-lg-5\">\r\n                  <form className=\"signin-form\">\r\n                    <div className=\"form-group mb-3 d-flex flex-row align-items-center\">\r\n                      <label class=\"col-md-2 form-control-label d-flex justify-content-center\">\r\n                        First Name\r\n                      </label>\r\n                      <div class=\"col-md-10\">\r\n                        <input\r\n                          class=\"form-control\"\r\n                          name=\"firstname\"\r\n                          type=\"text\"\r\n                          value={profile.firstname}\r\n                          onChange={onChange}\r\n                        />\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"form-group mb-3 d-flex flex-row align-items-center\">\r\n                      <label class=\"col-md-2 form-control-label d-flex justify-content-center\">\r\n                        Last Name\r\n                      </label>\r\n                      <div class=\"col-md-10\">\r\n                        <input\r\n                          class=\"form-control\"\r\n                          name=\"lastname\"\r\n                          type=\"text\"\r\n                          value={profile.lastname}\r\n                          onChange={onChange}\r\n                        />\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"form-group mb-3 d-flex flex-row align-items-center\">\r\n                      <label class=\"col-md-2 form-control-label d-flex justify-content-center\">\r\n                        Address\r\n                      </label>\r\n                      <div class=\"col-md-10\">\r\n                        <input\r\n                          class=\"form-control\"\r\n                          name=\"address\"\r\n                          type=\"text\"\r\n                          value={profile.address}\r\n                          onChange={onChange}\r\n                        />\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"form-group mb-3 d-flex flex-row align-items-center\">\r\n                      <label class=\"col-md-2 form-control-label d-flex justify-content-center\">\r\n                        City\r\n                      </label>\r\n                      <div class=\"col-md-10\">\r\n                        <input\r\n                          class=\"form-control\"\r\n                          name=\"city\"\r\n                          type=\"text\"\r\n                          value={profile.city}\r\n                          onChange={onChange}\r\n                        />\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"form-group mb-3 d-flex flex-row align-items-center\">\r\n                      <label class=\"col-md-2 form-control-label d-flex justify-content-center\">\